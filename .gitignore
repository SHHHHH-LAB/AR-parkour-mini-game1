# ===================== Unity 核心超大缓存文件夹（必加，解决几百MB上传） =====================
/Library/
/Logs/
/obj/
/UserSettings/
/Temp/
/Build/
/Builds/
/IL2CPP/
/.LocalTesting/

# 打包产物（体积巨大，完全不需要上传）
*.apk
*.ipa
*.exe
*.app
*.unitypackage

# ===================== Visual Studio / Rider 编译IDE文件 =====================
*.csproj
*.sln
*.vs
.vs/
*.suo
*.user
*.cache
*.log

# ===================== Unity 编辑器临时/备份文件 =====================
# 录制、截图、商店缓存
/Assets/*/Recordings/
/Assets/*/ScreenShots/
/Assets/AssetStoreTools*
/Assets/StreamingAssets.meta

# 工程设置备份
/ProjectSettings/*.bak
*.tmp
*.log
*.swp
*~

# Collab 云协作缓存
/Packages/com.unity.collab-proxy*/

# ===================== 系统隐藏垃圾文件 =====================
# Mac系统
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows系统
Thumbs.db
desktop.ini

# ===================== 其他杂项 =====================
# 本地密钥、配置
*.env
*.pem
*.key

# 压缩包
*.zip
*.rar
*.7z